APP_ENV=development

DATABASE_URL=postgresql+asyncpg://postgres:postgres@localhost:5432/specfit

OPENROUTER_API_KEY=
OPENROUTER_MODEL=openai/gpt-4o-mini
OPENROUTER_BASE_URL=https://openrouter.ai/api/v1

LOGFIRE_TOKEN=
LOGFIRE_SEND_TO_LOGFIRE=if-token-present

CORS_ORIGINS=http://localhost:3000

# Shared with the Next.js Worker. HS256 secret for backend bearer JWTs.
# Generate: openssl rand -base64 32
BACKEND_JWT_SECRET=

# Per-user daily input+output token cap for /applications/{id}/match.
DAILY_TOKEN_BUDGET=50000

# Resend (transactional email) — sender of verify + reset mails.
# The domain in EMAIL_FROM must be verified in Resend (DNS records) before sending.
# Format: either "email@domain" or RFC 5322 "Name <email@domain>".
RESEND_API_KEY=
EMAIL_FROM=SpecFit <specfit@rubrion.ai>

# Origin used to construct verify/reset URLs in outgoing emails.
# In production this MUST be the deployed Worker URL, not localhost,
# otherwise mailed links will 404 for users.
FRONTEND_BASE_URL=http://localhost:3000

# Shared with the Next.js Worker. Required header on /auth/oauth-upsert.
AUTH_SHARED_SECRET=

# Brave Search API key — used by /applications/{id}/suggested-profiles to look up
# LinkedIn profiles relevant to a job description. Empty disables the feature.
# Get one at https://brave.com/search/api/.
BRAVE_API_KEY=
BRAVE_SEARCH_URL=https://api.search.brave.com/res/v1/web/search

# Max upload size for PDF CV parsing.
CV_PDF_MAX_BYTES=5000000
