# Local development. Loaded by `next dev`.
# Copy to .env.local and override per developer.

# Backend API base URL.
NEXT_PUBLIC_API_URL=http://localhost:8787

# Auth.js session cookie/JWT encryption. 32+ random bytes.
# Generate: `openssl rand -base64 32`
AUTH_SECRET=

# HS256 secret — must match JWT_SECRET on the backend (curriclean-api).
JWT_SECRET=

# Shared secret sent on the X-Auth-Secret header when the Worker calls the backend's
# /auth/oauth-upsert endpoint. Must match AUTH_SHARED_SECRET on the backend.
AUTH_SHARED_SECRET=

# Optional Google OAuth. Set NEXT_PUBLIC_AUTH_GOOGLE_ENABLED=1 to show the button.
AUTH_GOOGLE_ID=
AUTH_GOOGLE_SECRET=
NEXT_PUBLIC_AUTH_GOOGLE_ENABLED=

# Optional GitHub OAuth. Set NEXT_PUBLIC_AUTH_GITHUB_ENABLED=1 to show the button.
AUTH_GITHUB_ID=
AUTH_GITHUB_SECRET=
NEXT_PUBLIC_AUTH_GITHUB_ENABLED=
