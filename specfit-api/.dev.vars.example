# .dev.vars — local development secrets for `wrangler dev`
# Copy to .dev.vars and fill in values. NEVER commit .dev.vars.

# JWT signing secret (any long random string)
JWT_SECRET=your_jwt_secret_here

# Server-to-server OAuth upsert shared secret (must match frontend)
AUTH_SHARED_SECRET=your_auth_shared_secret_here

# Resend transactional email API key
RESEND_API_KEY=re_xxxxxxxxxxxx

# Brave Search API key (for LinkedIn profile suggestions)
BRAVE_API_KEY=your_brave_api_key_here

# Optional: OpenRouter fallback LLM (leave blank to use Workers AI only)
OPENROUTER_API_KEY=
